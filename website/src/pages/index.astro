---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import MouseSpotlight from "../components/MouseSpotlight.astro";
import CursorFollower from "../components/CursorFollower.astro";
import SpecMarquee from "../components/SpecMarquee.astro";
import PageEnhancements from "../components/PageEnhancements.astro";
import Hero from "../components/Hero.astro";
import OnDevice from "../components/OnDevice.astro";
import Features from "../components/Features.astro";
import Comparison from "../components/Comparison.astro";
import Pricing from "../components/Pricing.astro";
import SocialProof from "../components/SocialProof.astro";
import FAQ from "../components/FAQ.astro";
import Footer from "../components/Footer.astro";

const description = "Talk to your Mac. Pace listens, reads your screen, and clicks for you — all on your own silicon. No accounts, no cloud, no monthly bill. One-time $29.";
---

<BaseLayout title="Pace — voice control for macOS, on-device" description={description}>
  <!-- Global decoration layers: ambient spotlight tracking the
       mouse + a custom blue cursor that mirrors Pace's actual
       in-app cursor. Both no-op on touch / coarse-pointer devices. -->
  <MouseSpotlight />
  <CursorFollower />
  <PageEnhancements />

  <Nav />
  <SpecMarquee />
  <main>
    <Hero />
    <OnDevice />
    <Features />
    <Comparison />
    <SocialProof />
    <Pricing />
    <FAQ />
  </main>
  <Footer />
</BaseLayout>

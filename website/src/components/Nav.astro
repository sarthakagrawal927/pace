---
// Pricing link in the header per the fleet landing standard. Single
// primary CTA in the nav matches the single primary CTA in the hero.
---

<header class="border-b border-[var(--color-border-subtle)] bg-black/80 backdrop-blur sticky top-0 z-40">
  <nav class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 text-white font-semibold tracking-tight text-lg">
      <span
        class="inline-flex items-end gap-[3px] h-5 w-6 text-[var(--color-accent)]"
        aria-hidden="true"
      >
        <span class="pace-bar h-3"></span>
        <span class="pace-bar h-5"></span>
        <span class="pace-bar h-4"></span>
        <span class="pace-bar h-3"></span>
      </span>
      Pace
    </a>

    <div class="hidden md:flex items-center gap-7 text-sm text-[var(--color-text-secondary)]">
      <a href="#what-it-does" class="hover:text-white transition-colors">What it does</a>
      <a href="#on-device" class="hover:text-white transition-colors">On-device</a>
      <a href="/compared" class="hover:text-white transition-colors">Compared</a>
      <a href="#pricing" class="hover:text-white transition-colors">Pricing</a>
      <a href="/download" class="hover:text-white transition-colors">Download</a>
      <a href="#faq" class="hover:text-white transition-colors">FAQ</a>
    </div>

    <a href="/download" class="pace-cta-primary text-sm py-2 px-4">
      Get Pace
      <span aria-hidden="true">→</span>
    </a>
  </nav>
</header>
